# Qingping developer app credentials, from qingping.co/developer
QINGPING_APP_ID=
QINGPING_APP_KEY=

# Optional: restrict to a specific device MAC (no colons, lowercase).
# Leave empty to pull all devices on your Qingping account.
QINGPING_DEVICE_MAC=

# Qingping API base URLs (Cleargrass is their parent company)
QINGPING_OAUTH_BASE=https://oauth.cleargrass.com
QINGPING_API_BASE=https://apis.cleargrass.com

# How often the cloud poller fetches the latest readings.
# Default every 5 minutes. Qingping rate-limits aggressively, don't go below 1m.
CRON_SCHEDULE=*/5 * * * *

# IANA timezone the cron fires in.
TIMEZONE=America/Los_Angeles

# Bearer token guarding the HTTP API. Required when deploying remotely.
# Generate with: openssl rand -hex 32
PANEL_BEARER_TOKEN=
